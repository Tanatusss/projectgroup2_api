generator client {
        provider = "prisma-client-js"
        output   = "../src/generated/prisma"
}

datasource db {
        provider = "mysql"
        url      = env("DATABASE_URL")
}

enum Roles {
        USER
        COMPANY
        ADMIN
}

model User {
        id           Int            @id @default(autoincrement())
        email        String         @unique
        password     String
        role         Roles          @default(USER)
        favoriteJob  FavoriteJob[]
        bookmarkType BookmarkType[]
        profile      ProfileUser[]
        resetTokens  ResetToken[]
}

model ResetToken {
        id        Int      @id @default(autoincrement())
        token     String   @unique
        userId    Int
        user      User     @relation(fields: [userId], references: [id])
        expiresAt DateTime
}

model Company {
        id         Int       @id @default(autoincrement())
        email      String    @unique
        name       String?
        password   String
        role       Roles     @default(COMPANY)
        phone      String?   @unique
        address    String?
        logoimage  String?
        link       String?
        jobPost    JobPost[]
        // Province   Province? @relation(fields: [provinceId], references: [id])
        // provinceId Int?
        District   District? @relation(fields: [districtId], references: [id])
        districtId Int?
}

enum Gender {
        MALE
        FEMALE
        OTHER
}

enum StartDate {
        NOW
        TWOWEEK
        FOURWEEK
        EIGHTWEEK
        TWELEWEEKPLUS
}

enum JobPreferences {
        FULLTIME
        PARTTIME
        CONTRACT
        CASUAL
}

model ProfileUser {
        id             Int             @id @default(autoincrement())
        firstname      String?
        lastname       String?
        birthdate      String?
        address        String?
        phone          String?         @unique
        gender         Gender? //ENUM
        expectsalary   Int?
        startdate      StartDate? //ENUM
        jobpreferences JobPreferences?

        user_id Int
        user    User @relation(fields: [user_id], references: [id])

        bookmarkType   BookmarkType[]
        workExperience WorkExperience[]
        education      Education[]
        Skills         Skills[]
        Certificate    Certificate[]
        Languages      Languages[]
        Resume         Resume[]
        jobApply       JobApply[]

        District   District? @relation(fields: [districtId], references: [id])
        districtId Int?
}

model Resume {
        id  Int    @id @default(autoincrement())
        url String

        profile_id  Int
        profileUser ProfileUser? @relation(fields: [profile_id], references: [id])
}

model Languages {
        id   Int    @id @default(autoincrement())
        name String

        profile_id  Int
        profileUser ProfileUser? @relation(fields: [profile_id], references: [id])
}

model Certificate {
        id  Int    @id @default(autoincrement())
        url String

        profile_id  Int
        profileUser ProfileUser? @relation(fields: [profile_id], references: [id])
}

model Skills {
        id   Int    @id @default(autoincrement())
        name String

        profile_id  Int
        profileUser ProfileUser? @relation(fields: [profile_id], references: [id])
}

model Education {
        id             Int     @id @default(autoincrement())
        qualification  String
        institute      String
        graduationYear Int
        otherCourses   String?

        profile_id  Int
        profileUser ProfileUser? @relation(fields: [profile_id], references: [id])
}

model WorkExperience {
        id          Int       @id @default(autoincrement())
        profile_id  Int
        jobPosition String?
        companyname String?
        salary      Int?
        startDate   DateTime?
        endDate     DateTime?

        profileUser ProfileUser? @relation(fields: [profile_id], references: [id])
}

model BookmarkType {
        id          Int          @id @default(autoincrement())
        user        User?        @relation(fields: [user_id], references: [id])
        profileUser ProfileUser? @relation(fields: [profile_id], references: [id])
        profile_id  Int?
        user_id     Int?
}

model FavoriteJob {
        id      Int     @id @default(autoincrement())
        user_id Int
        job_id  Int
        user    User    @relation(fields: [user_id], references: [id])
        job     JobPost @relation(fields: [job_id], references: [id])
}

model JobApply {
        id         Int         @id @default(autoincrement())
        profile_id Int
        job_id     Int
        profile    ProfileUser @relation(fields: [profile_id], references: [id])
        job        JobPost     @relation(fields: [job_id], references: [id])
        applyAt    DateTime    @default(now())
}

enum PostStatus {
        ACTIVE
        EXPIRED
}

model JobPost {
        id             Int           @id @default(autoincrement())
        company_id     Int
        company        Company       @relation(fields: [company_id], references: [id])
        title          String
        jobDescription String
        address        String
        salary         Int
        jobRequirement String
        createAt       DateTime      @default(now())
        status         PostStatus    @default(ACTIVE)
        favoriteJob    FavoriteJob[]
        jobApply       JobApply[]
        payment        Payment[]
        // Province       Province?     @relation(fields: [provinceId], references: [id])
        // provinceId     Int?
        District       District?     @relation(fields: [districtId], references: [id])
        districtId     Int?

        @@fulltext([title])
        @@fulltext([address])
        @@fulltext([jobDescription])
        @@fulltext([jobRequirement])
}

enum PaymentStatus {
        PENDING
        PAID
}

model Payment {
        id                Int           @id @default(autoincrement())
        job_id            Int
        job               JobPost       @relation(fields: [job_id], references: [id])
        session_url       String
        status            PaymentStatus @default(PENDING)
        paymentDate       DateTime?
        paymentMethod     String?
        price             Int
        stripe_payment_id Int?          @unique
        recover_url       String?
}


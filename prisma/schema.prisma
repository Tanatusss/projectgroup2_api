generator client {
        provider = "prisma-client-js"
        output   = "../src/generated/prisma"
}

datasource db {
        provider = "mysql"
        url      = env("DATABASE_URL")
}

enum Roles {
        USER
        COMPANY
        ADMIN
}

model User {
        id           Int                @id @default(autoincrement())
        email        String             @unique
        password     String
        role         Roles              @default(USER)
        favoriteJob  FavoriteJob[]
        bookmarkType BookmarkType[]
        profile      ProfileUser[]
        resetTokens  ResetToken[]
        refreshToken UserRefreshToken[]
}

model ResetToken {
        id        Int      @id @default(autoincrement())
        token     String   @unique
        userId    Int
        user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
        expiresAt DateTime
}

model Company {
        id          Int       @id @default(autoincrement())
        hrfirstname String?
        hrlastname  String?
        companyname String?
        phone       String?   @unique
        address     String?
        logoimage   String?
        image_bg    String?
        link        String?
        taxnumber   String?
        billaddress String?
        jobPost     JobPost[]
        district    District? @relation(fields: [districtId], references: [id], onDelete: Cascade, onUpdate: Cascade)
        districtId  Int?
}

enum Gender {
        MALE
        FEMALE
        OTHER
}

enum StartDate {
        NOW
        TWOWEEK
        FOURWEEK
        EIGHTWEEK
        TWELEWEEKPLUS
}

enum JobPreferences {
        FULLTIME
        PARTTIME
        CONTRACT
        CASUAL
}

model ProfileUser {
        id             Int             @id @default(autoincrement())
        firstname      String?
        lastname       String?
        address        String?
        description    String?
        phone          String?         @unique
        district       String?
        gender         Gender? //ENUM
        expectsalary   Int?
        startdate      StartDate? //ENUM
        jobpreferences JobPreferences? //ENUM

        user_id Int
        user    User @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

        workExperience WorkExperience[]
        education      Education[]
        Skills         Skills[]
        Certificate    Certificate[]
        Languages      Languages[]
        Resume         Resume[]
        jobApply       JobApply[]
}

model Resume {
        id   Int     @id @default(autoincrement())
        name String?
        url  String

        profile_id  Int
        profileUser ProfileUser? @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Languages {
        id   Int    @id @default(autoincrement())
        name String

        profile_id  Int
        profileUser ProfileUser? @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Certificate {
        id   Int     @id @default(autoincrement())
        name String?
        url  String

        profile_id  Int
        profileUser ProfileUser? @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Skills {
        id   Int    @id @default(autoincrement())
        name String

        profile_id  Int
        profileUser ProfileUser? @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Education {
        id             Int     @id @default(autoincrement())
        qualification  String
        institute      String
        graduationYear Int
        otherCourses   String?

        profile_id  Int
        profileUser ProfileUser? @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model WorkExperience {
        id          Int       @id @default(autoincrement())
        profile_id  Int
        jobPosition String?
        companyname String?
        salary      Int?
        startDate   DateTime?
        endDate     DateTime?

        profileUser ProfileUser? @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model BookmarkType {
        id      Int   @id @default(autoincrement())
        user    User? @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
        user_id Int?
}

model FavoriteJob {
        id      Int     @id @default(autoincrement())
        user_id Int
        job_id  Int
        user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
        job     JobPost @relation(fields: [job_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model JobApply {
        id         Int         @id @default(autoincrement())
        profile_id Int
        job_id     Int
        profile    ProfileUser @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
        job        JobPost     @relation(fields: [job_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
        applyAt    DateTime    @default(now())
}

enum PostStatus {
        ACTIVE
        EXPIRED
}

model JobPost {
        id             Int           @id @default(autoincrement())
        company_id     Int
        company        Company       @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
        title          String
        jobDescription String
        address        String
        salary         Int
        jobRequirement String
        typejob        String
        createAt       DateTime      @default(now())
        status         PostStatus    @default(ACTIVE)
        favoriteJob    FavoriteJob[]
        jobApply       JobApply[]
        payment        Payment[]
        district       District?     @relation(fields: [districtId], references: [id])
        districtId     Int?

        @@fulltext([title])
        @@fulltext([address])
        @@fulltext([jobDescription])
        @@fulltext([jobRequirement])
}

enum PaymentStatus {
        PENDING
        PAID
}

model Payment {
        id                Int           @id @default(autoincrement())
        job_id            Int
        job               JobPost       @relation(fields: [job_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
        session_url       String
        status            PaymentStatus @default(PENDING)
        paymentDate       DateTime?
        paymentMethod     String?
        price             Int
        stripe_payment_id Int?          @unique
        recover_url       String?
}

model District {
        id             Int      @id @default(autoincrement())
        districtCode   Int      @unique
        districtNameEn String
        districtNameTh String
        createdAt      DateTime @default(now())
        updatedAt      DateTime @updatedAt

        //relations
        jobPost   JobPost[]
        companies Company[]

        @@map("districts")
}

model Prompt {
        id       Int     @id @default(autoincrement())
        text     String
        keywords Json
        category String?
}

model UserRefreshToken {
        id        Int      @id @default(autoincrement())
        token     String   @unique
        userId    Int
        user      User     @relation(fields: [userId], references: [id])
        createdAt DateTime @default(now())
        expiredAt DateTime
        ipAddress String?
        userAgent String? // device user use to login
}

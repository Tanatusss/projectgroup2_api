generator client {
        provider = "prisma-client-js"
        output   = "../src/generated/prisma"
}

datasource db {
        provider = "mysql"
        url      = env("DATABASE_URL")
}

enum Roles {
        USER
        COMPANY
        ADMIN
}

model User {
        id           Int                @id @default(autoincrement())
        email        String             @unique
        password     String
        role         Roles              @default(USER)
        company      Company[]
        favoriteJob  FavoriteJob[]
        bookmarkType BookmarkType[]
        profile      ProfileUser[]
        resetTokens  ResetToken[]
        refreshToken UserRefreshToken[]
}

model ResetToken {
        id        Int      @id @default(autoincrement())
        token     String   @unique
        userId    Int
        user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
        expiresAt DateTime
}

model Company {
        id          Int       @id @default(autoincrement())
        hrfirstname String?
        hrlastname  String?
        companyname String?
        phone       String?   @unique
        address     String?
        logoimage   String?
        image_bg    String?
        link        String?
        taxnumber   String?
        billaddress String?
        description String?
        package     Package? @default(LITE) //ENUM
        websitecompany String?
        industrytype String?
        companysize String?
        primarylocation String?
        companyvision String?
        jobPost     JobPost[]
        User        User?     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
        user_id     Int?
}

enum Gender {
        MALE
        FEMALE
        OTHER
}

enum StartDate {
        NOW
        TWOWEEK
        FOURWEEK
        EIGHTWEEK
        TWELEWEEKPLUS
}

enum JobPreferences {
        FULLTIME
        PARTTIME
        CONTRACT
        CASUAL
}

model ProfileUser {
        id             Int             @id @default(autoincrement())
        firstname      String?
        lastname       String?
        address        String?
        description    String?
        phone          String?         @unique
        classsfication String?
        typejob        String?
        gender         Gender? //ENUM
        expectsalary   Int?
        startdate      StartDate? //ENUM
        jobpreferences JobPreferences? //ENUM
        preferredlocation String?
        user_id        Int
        user           User            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

        workExperience WorkExperience[]
        education      Education[]
        Skills         Skills[]
        Certificate    Certificate[]
        Languages      Languages[]
        Resume         Resume[]
        jobApply       JobApply[]
}

model Resume {
        id   Int     @id @default(autoincrement())
        name String?
        url  String

        profile_id  Int
        profileUser ProfileUser? @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Languages {
        id   Int    @id @default(autoincrement())
        name String

        profile_id  Int
        profileUser ProfileUser? @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Certificate {
        id   Int     @id @default(autoincrement())
        name String?
        url  String

        profile_id  Int
        profileUser ProfileUser? @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Skills {
        id   Int    @id @default(autoincrement())
        name String

        profile_id  Int
        profileUser ProfileUser? @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Education {
        id             Int     @id @default(autoincrement())
        qualification  String
        institute      String
        graduationYear Int
        otherCourses   String?

        profile_id  Int
        profileUser ProfileUser? @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

        @@map("education")
}

model WorkExperience {
        id          Int       @id @default(autoincrement())
        profile_id  Int
        jobPosition String?
        companyname String?
        salary      Int?
        startDate   DateTime?
        endDate     DateTime?

        profileUser ProfileUser? @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model BookmarkType {
        id        Int      @id @default(autoincrement())
        user      User?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
        user_id   Int?
        typejob   String
        createdAt DateTime @default(now())

        @@unique([user_id, typejob])
}

model FavoriteJob {
        id      Int     @id @default(autoincrement())
        user_id Int
        job_id  Int
        apply_at DateTime @default(now())
        user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
        job     JobPost @relation(fields: [job_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model JobApply {
        id           Int            @id @default(autoincrement())
        profile_id   Int
        jobpost_id Int
        profile      ProfileUser    @relation(fields: [profile_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
        applyAt      DateTime       @default(now())
        jobpost    JobPost     @relation(fields: [jobpost_id], references: [id])
        
        UserQuestion UserQuestion[]
}

enum PostStatus {
        ACTIVE
        EXPIRED
        DRAFT
}

enum Package {
        LITE
        BASIC
        PREMIUM
}

model JobPost {
        id                 Int                  @id @default(autoincrement())
        company_id         Int
        company            Company              @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
        title              String?
        jobDescription     String?
        address            String?
        salary             Int?
        jobRequirement     String?
        typejob            String?
        createAt           DateTime             @default(now())
        expireAt           DateTime?
        status             PostStatus           @default(ACTIVE)
        favoriteJob        FavoriteJob[]
        payment            Payment[]
        companyAnswer      CompanyAnswer[]
        jobApplies JobApply[]

        @@fulltext([title])
        @@fulltext([address])
        @@fulltext([jobDescription])
        @@fulltext([jobRequirement])
}

enum PaymentStatus {
        PENDING
        PAID
}

model Payment {
        id                Int           @id @default(autoincrement())
        job_id            Int
        job               JobPost       @relation(fields: [job_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
        session_url       String
        status            PaymentStatus @default(PENDING)
        paymentDate       DateTime?
        paymentMethod     String?
        price             Int
        stripe_payment_id Int?          @unique
        recover_url       String?
}

model Prompt {
        id       Int     @id @default(autoincrement())
        text     String
        keywords Json
        category String?
}

model UserRefreshToken {
        id        Int      @id @default(autoincrement())
        token     String
        userId    Int
        user      User     @relation(fields: [userId], references: [id])
        createdAt DateTime @default(now())
        expiredAt DateTime
        ipAddress String?
        userAgent String? // device user use to login
}

model QuestionData {
        id       Int    @id @default(autoincrement())
        typejob  String // ใช้กับงานประเภทใด
        question String

        answerData         AnswerData[] // คำตอบที่เป็นไปได้
        companyAnswers     CompanyAnswer[]      @relation("QuestionToCompanyAnswer")
        UserAnswer         UserAnswer[] // คำตอบที่ user ตอบ
        UserQuestion       UserQuestion[]
}

model AnswerData {
        id         Int    @id @default(autoincrement())
        questionId Int
        text       String

        question       QuestionData    @relation(fields: [questionId], references: [id])
        companyAnswers CompanyAnswer[] @relation("AnswerToCompanyAnswer")
        UserAnswer     UserAnswer[]
}

model CompanyAnswer {
        id             Int @id @default(autoincrement())
        jobpostId      Int
        questionId     Int
        answerOptionId Int

        jobpost      JobPost      @relation(fields: [jobpostId], references: [id])
        questionData QuestionData @relation("QuestionToCompanyAnswer", fields: [questionId], references: [id])
        answerData   AnswerData   @relation("AnswerToCompanyAnswer", fields: [answerOptionId], references: [id])

        @@unique([jobpostId, questionId, answerOptionId]) // ป้องกันซ้ำ
}

model UserQuestion {
        id         Int @id @default(autoincrement())
        jobApplyId Int
        questionId Int

        jobApply JobApply     @relation(fields: [jobApplyId], references: [id])
        question QuestionData @relation(fields: [questionId], references: [id])

        selectedOptions UserAnswer[]
}

model UserAnswer {
        id              Int @id @default(autoincrement())
        UserQuestion_Id Int
        answerOptionId  Int

        userAnswer     UserQuestion  @relation(fields: [UserQuestion_Id], references: [id])
        answerOption   AnswerData    @relation(fields: [answerOptionId], references: [id])
        
        QuestionData   QuestionData? @relation(fields: [questionDataId], references: [id])
        questionDataId Int?

        @@unique([UserQuestion_Id, answerOptionId]) // ป้องกันเลือกซ้ำ
}

